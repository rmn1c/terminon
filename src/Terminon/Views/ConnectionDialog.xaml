<Window x:Class="Terminon.Views.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Terminon.Converters"
        Title="New Connection"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- Title -->
        <TextBlock Text="New Connection" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

        <!-- Host / Port -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Hostname" Style="{DynamicResource FieldLabel}"/>
                <TextBox x:Name="HostBox" Style="{DynamicResource DarkTextBox}"
                         Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                         TabIndex="0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Port" Style="{DynamicResource FieldLabel}"/>
                <TextBox Style="{DynamicResource DarkTextBox}"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                         TabIndex="1"/>
            </StackPanel>
        </Grid>

        <!-- Username -->
        <Label Content="Username" Style="{DynamicResource FieldLabel}"/>
        <TextBox Style="{DynamicResource DarkTextBox}" Margin="0,0,0,12"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 TabIndex="2"/>

        <!-- Auth method -->
        <Label Content="Authentication" Style="{DynamicResource FieldLabel}"/>
        <ComboBox Style="{DynamicResource DarkComboBox}" Margin="0,0,0,12"
                  ItemsSource="{Binding AuthMethods}"
                  SelectedItem="{Binding AuthMethod}"
                  TabIndex="3"/>

        <!-- Password auth -->
        <StackPanel Visibility="{Binding IsPasswordAuth, Converter={StaticResource BoolToVis}}">
            <Label Content="Password" Style="{DynamicResource FieldLabel}"/>
            <PasswordBox x:Name="PasswordBox" Style="{DynamicResource DarkPasswordBox}"
                         Margin="0,0,0,12" TabIndex="4"/>
        </StackPanel>

        <!-- Key file auth -->
        <StackPanel Visibility="{Binding IsPasswordAuth, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <Label Content="Private Key File" Style="{DynamicResource FieldLabel}"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{DynamicResource DarkTextBox}"
                         Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}"
                         TabIndex="5"/>
                <Button Grid.Column="1" Content="Browse…" Style="{StaticResource SecondaryButton}"
                        Margin="6,0,0,0" Command="{Binding BrowseKeyFileCommand}"/>
            </Grid>
            <Label Content="Passphrase (if protected)" Style="{DynamicResource FieldLabel}"/>
            <PasswordBox x:Name="PassphraseBox" Style="{DynamicResource DarkPasswordBox}"
                         Margin="0,0,0,12" TabIndex="6"/>
        </StackPanel>

        <!-- Save profile -->
        <Separator Style="{DynamicResource DarkSeparator}"/>
        <CheckBox Style="{DynamicResource DarkCheckBox}" Margin="0,8,0,8"
                  Content="Save this connection" IsChecked="{Binding SaveProfile}"/>

        <StackPanel Visibility="{Binding SaveProfile, Converter={StaticResource BoolToVis}}">
            <Label Content="Profile name (optional)" Style="{DynamicResource FieldLabel}"/>
            <TextBox Style="{DynamicResource DarkTextBox}" Margin="0,0,0,8"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     TabIndex="7"/>
        </StackPanel>

        <!-- Error message -->
        <TextBlock x:Name="ErrorText" Foreground="{DynamicResource DangerBrush}" FontSize="12"
                   Margin="0,4,0,8" TextWrapping="Wrap"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"/>

        <!-- Buttons -->
        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Grid.Column="3" Content="Connect" Style="{StaticResource PrimaryButton}"
                    Command="{Binding ConnectCommand}" IsDefault="True"/>
        </Grid>
    </StackPanel>
</Window>
