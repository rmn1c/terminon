<Window x:Class="Terminon.Views.KeyGenerationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Terminon.Converters"
        Title="SSH Key Generation"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="Generate SSH Key Pair" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

        <!-- Algorithm -->
        <Label Content="Algorithm" Style="{DynamicResource FieldLabel}"/>
        <ComboBox Style="{DynamicResource DarkComboBox}" Margin="0,0,0,12"
                  ItemsSource="{Binding Algorithms}" SelectedItem="{Binding Algorithm}"/>

        <!-- Comment -->
        <Label Content="Comment (identifies the key)" Style="{DynamicResource FieldLabel}"/>
        <TextBox Style="{DynamicResource DarkTextBox}" Margin="0,0,0,12"
                 Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Save location -->
        <Label Content="Save directory" Style="{DynamicResource FieldLabel}"/>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{DynamicResource DarkTextBox}"
                     Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Grid.Column="1" Content="Browse…" Style="{StaticResource SecondaryButton}"
                    Margin="6,0,0,0" Command="{Binding BrowseDirectoryCommand}"/>
        </Grid>

        <Label Content="Key name" Style="{DynamicResource FieldLabel}"/>
        <TextBox Style="{DynamicResource DarkTextBox}" Margin="0,0,0,16"
                 Text="{Binding KeyName, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Generate button -->
        <Button Content="Generate Key Pair" Style="{StaticResource PrimaryButton}"
                Command="{Binding GenerateCommand}" HorizontalAlignment="Left"/>

        <!-- Status message -->
        <TextBlock Text="{Binding StatusMessage}" FontSize="12" Margin="0,8,0,0"
                   Foreground="{DynamicResource SubtextBrush}"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVis}}"/>

        <!-- Result -->
        <Border Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource Surface0Brush}" CornerRadius="6" Padding="12" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Public Key" Style="{DynamicResource FieldLabel}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding GeneratedPublicKey, Mode=OneWay}" IsReadOnly="True"
                         Style="{DynamicResource DarkTextBox}" FontFamily="Cascadia Code" FontSize="11"
                         TextWrapping="Wrap" MaxHeight="80" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="{Binding Fingerprint}" FontSize="11" Margin="0,8,0,0"
                           Foreground="{DynamicResource SubtextBrush}" FontFamily="Cascadia Code"/>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Copy Public Key" Style="{StaticResource SecondaryButton}"
                            Command="{Binding CopyPublicKeyCommand}" Margin="0,0,8,0"/>
                    <Button Content="Save to Disk" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Close -->
        <Button Content="Close" Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Command="{Binding CloseCommand}" IsCancel="True"/>
    </StackPanel>
</Window>
