<Window x:Class="Terminon.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Terminon.ViewModels"
        xmlns:ctrl="clr-namespace:Terminon.Controls"
        xmlns:conv="clr-namespace:Terminon.Converters"
        xmlns:views="clr-namespace:Terminon.Views"
        mc:Ignorable="d"
        x:Name="MainWnd"
        Title="{Binding AppTitle}"
        Height="800" Width="1200"
        MinHeight="400" MinWidth="700"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding NewTabCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}"/>
        <KeyBinding Key="Tab" Modifiers="Ctrl" Command="{Binding NextTabCommand}"/>
        <KeyBinding Key="Tab" Modifiers="Ctrl+Shift" Command="{Binding PrevTabCommand}"/>
        <KeyBinding Key="D1" Modifiers="Ctrl" CommandParameter="0"/>
        <KeyBinding Key="B" Modifiers="Ctrl" Command="{Binding ToggleSidebarCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Quick connect bar -->
            <RowDefinition Height="*"/>       <!-- Main content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Quick Connect Bar ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource QuickConnectBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / title -->
                <TextBlock Grid.Column="0" Text="⚡ Terminon" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="4,0,12,0"/>

                <!-- New tab -->
                <Button Grid.Column="1" Content="＋  New Tab" Style="{StaticResource IconButton}"
                        Command="{Binding NewTabCommand}" ToolTip="New Tab (Ctrl+T)" Margin="0,0,4,0"/>

                <!-- Quick connect input -->
                <TextBox Grid.Column="2" Style="{DynamicResource DarkTextBox}"
                         Text="{Binding QuickConnectText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Tag="user@host[:port]">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding QuickConnectCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="3" Content="→" Style="{StaticResource IconButton}"
                        Command="{Binding QuickConnectCommand}" Margin="2,0,0,0"/>

                <!-- Recent connections dropdown -->
                <ComboBox Grid.Column="4" Style="{DynamicResource DarkComboBox}"
                          ItemsSource="{Binding RecentConnections}"
                          DisplayMemberPath="Name"
                          Margin="8,0,0,0" MaxWidth="250"
                          SelectedItem="{Binding SelectedRecent}"
                          ToolTip="Recent connections">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="12"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Sidebar toggle -->
                <Button Grid.Column="5" Content="◧" Style="{StaticResource IconButton}"
                        Command="{Binding ToggleSidebarCommand}" ToolTip="Toggle Sidebar (Ctrl+B)" Margin="4,0"/>

                <!-- Key gen -->
                <Button Grid.Column="6" Content="🔑" Style="{StaticResource IconButton}"
                        Command="{Binding OpenKeygenCommand}" ToolTip="Generate SSH Key"/>

                <!-- Settings -->
                <Button Grid.Column="7" Content="⚙" Style="{StaticResource IconButton}"
                        Command="{Binding OpenSettingsCommand}" ToolTip="Settings" Margin="4,0"/>
            </Grid>
        </Border>

        <!-- ═══ Main Content ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" x:Name="SidebarColumn"
                                  MinWidth="0" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Sidebar header -->
                    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="8,6">
                        <Grid>
                            <TextBlock Text="CONNECTIONS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource OverlayBrush}" LetterSpacing="1"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="＋" Style="{StaticResource IconButton}" FontSize="14"
                                        Command="{Binding OpenConnectionDialogCommand}"
                                        ToolTip="Add connection" Padding="4"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Connection tree -->
                    <TreeView Grid.Row="1" x:Name="ConnectionTree"
                              ItemsSource="{Binding ConnectionTree}"
                              Style="{DynamicResource DarkTreeView}"
                              VirtualizingPanel.IsVirtualizing="True">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value=""/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                        <Setter Property="Text" Value="📁"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                                        <Setter Property="Text" Value="🖥"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                    <Button Grid.Column="2" Content="→" Style="{StaticResource IconButton}" Padding="2"
                                            FontSize="11"
                                            Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                            Tag="{Binding Profile}"
                                            Click="ConnectFromSidebar_Click"/>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource DarkTreeViewItem}">
                                <EventSetter Event="MouseDoubleClick" Handler="TreeItem_DoubleClick"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Sidebar resizer -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center"
                          Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- Tab area -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab bar -->
                <Border Grid.Row="0" Background="{DynamicResource TabBarBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Tabs}" x:Name="TabBar">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                    <Border x:Name="TabBorder" MinWidth="120" MaxWidth="200"
                                            Padding="8,5" Cursor="Hand"
                                            Background="{DynamicResource InactiveTabBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,1,0"
                                            MouseDown="TabHeader_MouseDown">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Status dot -->
                                            <Ellipse Grid.Column="0" Width="7" Height="7" Margin="0,0,5,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource OverlayBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                       FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="2" Content="✕" Style="{StaticResource TabCloseButton}"
                                                    Tag="{Binding}"
                                                    Click="CloseTab_Click"/>
                                        </Grid>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.ActiveTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="{Binding}">
                                                        <Setter Property="Background" Value="{DynamicResource ActiveTabBrush}"/>
                                                        <Setter Property="BorderThickness" Value="0,2,1,0"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Terminal / SFTP content -->
                <Grid Grid.Row="1" x:Name="ContentArea">
                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasActiveTab, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                        <TextBlock Text="⚡" FontSize="64" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock Text="Terminon" FontSize="32" FontWeight="Light"
                                   Foreground="{DynamicResource SubtextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Press Ctrl+T to open a new connection" FontSize="14"
                                   Foreground="{DynamicResource OverlayBrush}" HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <Button Content="New Connection" Style="{StaticResource PrimaryButton}"
                                Command="{Binding NewTabCommand}" HorizontalAlignment="Center"
                                Margin="0,20,0,0"/>
                    </StackPanel>

                    <!-- Active session -->
                    <Grid Visibility="{Binding HasActiveTab, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Search bar -->
                            <RowDefinition Height="*"/>    <!-- Terminal + SFTP -->
                        </Grid.RowDefinitions>

                        <!-- Search bar (conditionally shown) -->
                        <ctrl:SearchBar Grid.Row="0" x:Name="SearchBarControl"
                                        DataContext="{Binding ActiveTab}"
                                        Visibility="{Binding ActiveTab.IsSearchVisible, ElementName=MainWnd, Converter={StaticResource BoolToVis}}"
                                        Margin="8,4"/>

                        <!-- Terminal / SFTP split -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition x:Name="SftpSplitterCol" Width="Auto"/>
                                <ColumnDefinition x:Name="SftpCol" Width="0"/>
                            </Grid.ColumnDefinitions>

                            <!-- Terminal control -->
                            <ctrl:TerminalControl Grid.Column="0" x:Name="TermCtrl"
                                                  Session="{Binding ActiveTab}"/>

                            <!-- SFTP panel splitter -->
                            <GridSplitter Grid.Column="1" Width="4"
                                          Background="{DynamicResource BorderBrush}"
                                          HorizontalAlignment="Center"
                                          Visibility="{Binding ActiveTab.IsSftpVisible, ElementName=MainWnd, Converter={StaticResource BoolToVis}}"/>

                            <!-- SFTP panel -->
                            <views:SftpPanel Grid.Column="2" x:Name="SftpPanelCtrl"
                                             DataContext="{Binding ActiveTab.SftpPanel}"
                                             Visibility="{Binding ActiveTab.IsSftpVisible, ElementName=MainWnd, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══ Status Bar ════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="8,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding ActiveTab.StatusText}"
                           Foreground="{DynamicResource SubtextBrush}" FontSize="12" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" FontSize="12" VerticalAlignment="Center" Margin="12,0"
                           Foreground="{DynamicResource OverlayBrush}"
                           Visibility="{Binding ActiveTab.IsConnected, Converter={StaticResource BoolToVis}}">
                    <Run Text="Latency: "/>
                    <Run Text="{Binding ActiveTab.LatencyMs}"/>
                    <Run Text=" ms"/>
                </TextBlock>

                <TextBlock Grid.Column="2" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"
                           Foreground="{DynamicResource OverlayBrush}"
                           Visibility="{Binding ActiveTab.IsConnected, Converter={StaticResource BoolToVis}}">
                    <Run Text="Up: "/>
                    <Run Text="{Binding ActiveTab.Uptime, StringFormat=hh\\:mm\\:ss}"/>
                </TextBlock>

                <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"
                           Foreground="{DynamicResource OverlayBrush}">
                    <Run Text="{Binding Tabs.Count}"/>
                    <Run Text=" tab(s)"/>
                </TextBlock>

                <TextBlock Grid.Column="4" Text="Terminon v1.0" FontSize="12"
                           Foreground="{DynamicResource OverlayBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
