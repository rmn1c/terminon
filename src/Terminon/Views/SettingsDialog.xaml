<Window x:Class="Terminon.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Terminon.Converters"
        Title="Settings"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

        <!-- Appearance -->
        <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource OverlayBrush}" Margin="0,0,0,8"/>
        <Border Background="{DynamicResource Surface0Brush}" CornerRadius="6" Padding="12" Margin="0,0,0,16">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="Theme" Style="{DynamicResource FieldLabel}"/>
                        <ComboBox Style="{DynamicResource DarkComboBox}" ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="Font Size" Style="{DynamicResource FieldLabel}"/>
                        <TextBox Style="{DynamicResource DarkTextBox}" Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
                <Label Content="Font Family" Style="{DynamicResource FieldLabel}"/>
                <ComboBox Style="{DynamicResource DarkComboBox}" ItemsSource="{Binding FontFamilies}" SelectedItem="{Binding FontFamily}" IsEditable="True"/>
            </StackPanel>
        </Border>

        <!-- Terminal -->
        <TextBlock Text="TERMINAL" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource OverlayBrush}" Margin="0,0,0,8"/>
        <Border Background="{DynamicResource Surface0Brush}" CornerRadius="6" Padding="12" Margin="0,0,0,16">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="Scrollback Lines" Style="{DynamicResource FieldLabel}"/>
                        <TextBox Style="{DynamicResource DarkTextBox}" Text="{Binding ScrollbackLines, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="Bell Mode" Style="{DynamicResource FieldLabel}"/>
                        <ComboBox Style="{DynamicResource DarkComboBox}" ItemsSource="{Binding BellModes}" SelectedItem="{Binding BellMode}"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="Bracketed paste mode" Style="{DynamicResource DarkCheckBox}" IsChecked="{Binding BracketedPaste}"/>
                    <StackPanel Grid.Column="2">
                        <Label Content="Cursor blink rate (ms)" Style="{DynamicResource FieldLabel}"/>
                        <TextBox Style="{DynamicResource DarkTextBox}" Text="{Binding CursorBlinkRateMs, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Behavior -->
        <TextBlock Text="BEHAVIOR" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource OverlayBrush}" Margin="0,0,0,8"/>
        <Border Background="{DynamicResource Surface0Brush}" CornerRadius="6" Padding="12" Margin="0,0,0,16">
            <StackPanel>
                <CheckBox Content="Close tab when connection drops" Style="{DynamicResource DarkCheckBox}"
                          IsChecked="{Binding CloseTabOnDisconnect}" Margin="0,0,0,6"/>
                <CheckBox Content="Confirm before closing the application" Style="{DynamicResource DarkCheckBox}"
                          IsChecked="{Binding ConfirmOnClose}" Margin="0,0,0,6"/>
                <CheckBox Content="Minimize to system tray" Style="{DynamicResource DarkCheckBox}"
                          IsChecked="{Binding MinimizeToTray}"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Reset Defaults" Style="{StaticResource SecondaryButton}" Command="{Binding ResetCommand}"/>
            <Button Grid.Column="2" Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Grid.Column="4" Content="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" IsDefault="True"/>
        </Grid>
    </StackPanel>
</Window>
