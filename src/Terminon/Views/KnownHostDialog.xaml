<Window x:Class="Terminon.Views.KnownHostDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Host Key Verification"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ShowInTaskbar="False">

    <StackPanel Margin="24">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock x:Name="IconBlock" Text="⚠" FontSize="32" Margin="0,0,12,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TitleBlock" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock x:Name="SubtitleBlock" FontSize="12"
                           Foreground="{DynamicResource SubtextBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Background="{DynamicResource Surface0Brush}" CornerRadius="6" Padding="12" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Key Type:" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,2"/>
                <TextBlock x:Name="KeyTypeBlock" FontSize="13" Foreground="{DynamicResource TextBrush}"
                           FontFamily="Cascadia Code" Margin="0,0,0,10"/>
                <TextBlock Text="Fingerprint (SHA-256):" FontSize="12"
                           Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,2"/>
                <TextBlock x:Name="FingerprintBlock" FontSize="12" Foreground="{DynamicResource TextBrush}"
                           FontFamily="Cascadia Code" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock x:Name="WarningBlock" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,16"
                   Foreground="{DynamicResource WarningBrush}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RejectButton" Content="Reject" Style="{StaticResource DangerButton}"
                    IsCancel="True" Click="Reject_Click" Margin="0,0,8,0"/>
            <Button x:Name="AcceptButton" Content="Accept and Connect" Style="{StaticResource PrimaryButton}"
                    Click="Accept_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
