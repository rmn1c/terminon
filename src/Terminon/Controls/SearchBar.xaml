<UserControl x:Class="Terminon.Controls.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="36">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="SearchBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border Background="#CC1E1E2E" CornerRadius="4">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="SearchTextBox"
                 Grid.Column="0"
                 Background="#313244"
                 Foreground="#CDD6F4"
                 CaretBrush="#CDD6F4"
                 BorderThickness="0"
                 Padding="8,4"
                 VerticalAlignment="Center"
                 FontSize="13"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 KeyDown="SearchTextBox_KeyDown">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TextBox">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TextBox.Style>
        </TextBox>
        <TextBlock x:Name="HitCount" Grid.Column="1" Text="0 results"
                   Foreground="#6C7086" VerticalAlignment="Center" FontSize="12" Margin="4,0"/>
        <Button Grid.Column="2" Content="↑" Style="{StaticResource SearchBtn}" Click="PrevHit_Click" ToolTip="Previous (Shift+Enter)"/>
        <Button Grid.Column="3" Content="↓" Style="{StaticResource SearchBtn}" Click="NextHit_Click" ToolTip="Next (Enter)"/>
        <Button Grid.Column="4" Content="✕" Style="{StaticResource SearchBtn}" Click="Close_Click" ToolTip="Close (Escape)"/>
    </Grid>
    </Border>
</UserControl>
