<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F8F8F2"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#EDEDF0"/>
    <SolidColorBrush x:Key="TabBarBackgroundBrush" Color="#E0E0E8"/>
    <SolidColorBrush x:Key="ActiveTabBrush" Color="#F8F8F2"/>
    <SolidColorBrush x:Key="InactiveTabBrush" Color="#EDEDF0"/>
    <SolidColorBrush x:Key="TextBrush" Color="#282A36"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#6272A4"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#6272A4"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#CCCCDD"/>
    <SolidColorBrush x:Key="Surface0Brush" Color="#EDEDF0"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="#E0E0E8"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="#888899"/>
    <SolidColorBrush x:Key="StatusBarBrush" Color="#E0E0E8"/>
    <SolidColorBrush x:Key="QuickConnectBrush" Color="#EDEDF0"/>

    <Style TargetType="TextBox" x:Key="DarkTextBox">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#282A36"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="PasswordBox" x:Key="DarkPasswordBox">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#282A36"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="ComboBox" x:Key="DarkComboBox">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#282A36"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="DangerButton">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Label" x:Key="FieldLabel">
        <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="0,0,0,2"/>
    </Style>

    <Style TargetType="CheckBox" x:Key="DarkCheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="RadioButton" x:Key="DarkRadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,2"/>
    </Style>

    <Style TargetType="ListView" x:Key="DarkListView">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TreeView" x:Key="DarkTreeView">
        <Setter Property="Background" Value="{StaticResource SidebarBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TreeViewItem" x:Key="DarkTreeViewItem">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Padding" Value="4,3"/>
    </Style>

    <Style TargetType="ProgressBar" x:Key="DarkProgressBar">
        <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="4"/>
    </Style>

    <Style TargetType="TabControl" x:Key="DarkTabControl">
        <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="Slider" x:Key="DarkSlider">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
    </Style>

</ResourceDictionary>
