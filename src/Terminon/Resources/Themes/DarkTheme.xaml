<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Catppuccin Mocha palette -->
    <Color x:Key="Base">#1E1E2E</Color>
    <Color x:Key="Mantle">#181825</Color>
    <Color x:Key="Crust">#11111B</Color>
    <Color x:Key="Surface0">#313244</Color>
    <Color x:Key="Surface1">#45475A</Color>
    <Color x:Key="Surface2">#585B70</Color>
    <Color x:Key="Overlay0">#6C7086</Color>
    <Color x:Key="Overlay1">#7F849C</Color>
    <Color x:Key="Overlay2">#9399B2</Color>
    <Color x:Key="Text">#CDD6F4</Color>
    <Color x:Key="Subtext0">#A6ADC8</Color>
    <Color x:Key="Blue">#89B4FA</Color>
    <Color x:Key="Lavender">#B4BEFE</Color>
    <Color x:Key="Green">#A6E3A1</Color>
    <Color x:Key="Red">#F38BA8</Color>
    <Color x:Key="Yellow">#F9E2AF</Color>
    <Color x:Key="Peach">#FAB387</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource Base}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource Mantle}"/>
    <SolidColorBrush x:Key="TabBarBackgroundBrush" Color="{StaticResource Crust}"/>
    <SolidColorBrush x:Key="ActiveTabBrush" Color="{StaticResource Base}"/>
    <SolidColorBrush x:Key="InactiveTabBrush" Color="{StaticResource Mantle}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource Text}"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource Subtext0}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Blue}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Red}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Green}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Yellow}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Surface0}"/>
    <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0}"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource Overlay0}"/>
    <SolidColorBrush x:Key="StatusBarBrush" Color="{StaticResource Crust}"/>
    <SolidColorBrush x:Key="QuickConnectBrush" Color="{StaticResource Mantle}"/>

    <!-- Input controls -->
    <Style TargetType="TextBox" x:Key="DarkTextBox">
        <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="PasswordBox" x:Key="DarkPasswordBox">
        <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="ComboBox" x:Key="DarkComboBox">
        <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TabBarBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.9"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Button" x:Key="DangerButton">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TabBarBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Label" x:Key="FieldLabel">
        <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="0,0,0,2"/>
    </Style>

    <Style TargetType="CheckBox" x:Key="DarkCheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="RadioButton" x:Key="DarkRadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,2"/>
    </Style>

    <Style TargetType="Slider" x:Key="DarkSlider">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
    </Style>

    <Style TargetType="ListView" x:Key="DarkListView">
        <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TreeView" x:Key="DarkTreeView">
        <Setter Property="Background" Value="{StaticResource SidebarBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TreeViewItem" x:Key="DarkTreeViewItem">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Padding" Value="4,3"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ProgressBar" x:Key="DarkProgressBar">
        <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="4"/>
    </Style>

    <Style TargetType="ScrollBar" x:Key="DarkScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
    </Style>

    <Style TargetType="TabControl" x:Key="DarkTabControl">
        <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

</ResourceDictionary>
